@model Tarea4SeleniumApp.Models.Videojuego

@{
    ViewData["Title"] = "Editar Juego";
}

<div class="container mt-4">
    <h2>Editar Videojuego</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div class="form-group mb-3">
                    <label asp-for="Titulo" class="control-label fw-bold">Título</label>
                    <input asp-for="Titulo" class="form-control" id="Titulo" required />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Genero" class="control-label fw-bold">Género</label>
                    <input asp-for="Genero" class="form-control" id="Genero" required />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Plataforma" class="control-label fw-bold">Plataforma</label>
                    <input asp-for="Plataforma" class="form-control" id="Plataforma" required />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Precio" class="control-label fw-bold">Precio</label>
                    <input asp-for="Precio" class="form-control" id="Precio" required />
                </div>
                <div class="form-group mt-4">
                    <input type="submit" value="Actualizar" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>