@model Tarea4SeleniumApp.Models.Videojuego

@{
    ViewData["Title"] = "Eliminar Juego";
}

<div class="container mt-4">
    <h2 class="text-danger">¿Estás seguro de que quieres eliminar este juego?</h2>
    <hr />
    <div>
        <dl class="row">
            <dt class="col-sm-2 fw-bold">Título</dt>
            <dd class="col-sm-10">@Model.Titulo</dd>
            <dt class="col-sm-2 fw-bold">Género</dt>
            <dd class="col-sm-10">@Model.Genero</dd>
            <dt class="col-sm-2 fw-bold">Precio</dt>
            <dd class="col-sm-10">@Model.Precio</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Eliminar" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
        </form>
    </div>
</div>