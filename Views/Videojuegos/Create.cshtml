@model Tarea4SeleniumApp.Models.Videojuego

@{
    ViewData["Title"] = "Registrar Nuevo Juego";
}

<div class="container mt-4">
    <h2>Registrar Nuevo Juego</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create">
                <div class="form-group mb-3">
                    <label asp-for="Titulo" class="control-label fw-bold">Título</label>
                    <input asp-for="Titulo" class="form-control" id="Titulo" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Genero" class="control-label fw-bold">Género</label>
                    <input asp-for="Genero" class="form-control" id="Genero" />
                    <span asp-validation-for="Genero" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Plataforma" class="control-label fw-bold">Plataforma</label>
                    <input asp-for="Plataforma" class="form-control" id="Plataforma" />
                    <span asp-validation-for="Plataforma" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Precio" class="control-label fw-bold">Precio</label>
                    <input asp-for="Precio" class="form-control" id="Precio" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>
                <div class="form-group mt-4">
                    <input type="submit" value="Guardar Juego" class="btn btn-success" />
                    <a asp-action="Index" class="btn btn-secondary ms-2">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}